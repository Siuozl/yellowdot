    "bg_top":                 "#0D0A00EE",
    "bg_bottom":              "#0D0A00AA",
    "blur":                   "16px",
    "saturate":               "180%",
    "border_color":           "#FFD70022",
    "glow_line_enabled":      "true",
    "glow_line_color_edge":   "var(--gold)",
    "glow_line_color_mid":    "var(--gold-bright)",
    "glow_line_dot_color":    "var(--gold-bright)",
