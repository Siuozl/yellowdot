    "cream":       "#FFFBE6",
    "cream2":      "#FFF7D0",
    "page_bg":     "#0D0A00"
  },

  "shadows": {
    "glow_sm": "0 0 8px #FFD70088, 0 0 18px #F5C51844",
    "glow_md": "0 0 12px #FFD700AA, 0 0 30px #F5C51866, 0 0 60px #B8860B33",
    "glow_lg": "0 0 20px #FFD700CC, 0 0 50px #F5C51888, 0 0 100px #B8860B44"
