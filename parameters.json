  },

  "particles": {
    "enabled":      "true",
    "count":        "28",
    "color":        "#FFD700",
    "glow":         "0 0 8px #FFD70088, 0 0 18px #F5C51844",
    "min_size":     "1",
    "max_size":     "4",
    "min_duration": "8",
    "max_duration": "22",
    "max_delay":    "12",
    "opacity_peak": "0.6",
    "opacity_fade": "0.3"
